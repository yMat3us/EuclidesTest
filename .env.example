# Senha do modo professor (obrigatório em produção)
DDM_ADMIN_TOKEN=ddm-escola-2026

# Opcional
PORT=3000
HOST=0.0.0.0
# DDM_DB_PATH=/caminho/ranking.db

# Chave de API do Gemini para o Chatbot Conversacional
GEMINI_API_KEY=sua_chave_do_gemini
# Modelo do Gemini para uso (ex: gemini-3.5-flash, gemini-2.5-flash, gemini-2.0-flash)
GEMINI_MODEL=gemini-2.5-flash

# ==========================================
# CONFIGURAÇÕES DE WHATSAPP (OPCIONAL)
# ==========================================

# Número do administrador autorizado para receber notificações e enviar comandos (ex: 5581999999999)
WHATSAPP_ADMIN_NUMBER=5581999999999

# Provedor da API de envio: 'evolution', 'twilio', 'zapi' ou deixar em branco para mock no console
WHATSAPP_PROVIDER=evolution

# URL de envio da API (Obrigatória se não for Twilio e não for mock)
# Evolution: http://suainstancia.com/message/sendText/nomedainstancia
# Z-API: https://api.z-api.io/instances/SUA_INSTANCIA/token/SEU_TOKEN/send-text
WHATSAPP_API_URL=http://localhost:8080/message/sendText/admin

# Token / API Key de autenticação do provedor (usado para Evolution ou Z-API)
WHATSAPP_API_KEY=seu_token_da_api

# --- Configurações Específicas do Twilio (caso WHATSAPP_PROVIDER=twilio) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxx
TWILIO_AUTH_TOKEN=auth_token_aqui
TWILIO_PHONE_NUMBER=whatsapp:+14155238886